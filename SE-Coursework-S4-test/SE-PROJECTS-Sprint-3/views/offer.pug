extends layout

block content
  .page-header
    h2 Offer a Ride
    p Share your journey and earn double points

  .card
    if error
      .error-banner= error
    if success
      .success-banner= success

    form(action='/offer', method='POST')
      .grid-2
        .field
          label(for='pickup') Pickup location
          input#pickup(type='text', name='pickup', placeholder='e.g. Tooting Broadway', required)
        .field
          label(for='destination') Destination
          input#destination(type='text', name='destination', placeholder='e.g. Main Campus', required)

      .grid-2
        .field
          label(for='date') Date
          input#date(type='date', name='date', required)
        .field
          label(for='time') Time
          input#time(type='time', name='time', required)

      .field
        label(for='seats') Available seats
        select#seats(name='seats', required)
          option(value='1') 1 seat
          option(value='2') 2 seats
          option(value='3') 3 seats
          option(value='4') 4 seats

      .field
        label Tag
        .tag-select
          each t in ['Quiet Ride', 'Music OK', 'Pets OK', 'Ladies Only', 'Early Bird']
            label.tag-option
              input(type='radio', name='tag', value=t)
              span= t

      .field
        label(for='notes') Additional notes
        textarea#notes(name='notes', placeholder='Anything passengers should know...', rows='3')

      .points-notice
        | ★ You'll earn&nbsp;
        strong +2 points
        |  for offering this ride. Drivers earn double!

      button.gbtn(type='submit') Post Ride →
