extends layout

block content
  .page-header
    h2 Find a Ride
    p Browse available carpools from the verified student community

  //- Search and Filter Section
  .card.search-card
    form.search-form(action='/listing', method='GET')
      .search-grid
        input.search-input(
          type='text',
          name='destination',
          placeholder='Where to? e.g. Library, Main Campus',
          value=query || ''
        )
        input.search-input.date-input(
          type='date',
          name='date',
          value=dateQuery || ''
        )
        button.gbtn-sm(type='submit') Search

  //- Quick Filter Tags
  .tag-filters
    a.tag(href='/listing', class=!activeTag ? 'active' : '') All
    each val in ['Morning', 'Afternoon', 'Evening', 'Quiet Ride', 'Music OK']
      a.tag(
        href=`/listing?tag=${val}`, 
        class=activeTag === val ? 'active' : ''
      )= val

  //- User Case 8: Map Visualization
  .map-container
    div#map(style="height: 400px; width: 100%; margin-bottom: 20px; border-radius: 8px; border: 1px solid #ddd;")

  //- Rides Display Logic
  if rides && rides.length > 0
    .rides-list
      each ride in rides
        a.ride-card(href=`/detail/${ride.id}`)
          .ride-route
            span.location= ride.pickup || 'Campus'
            span.ride-arrow →
            span.location= ride.destination
            span.badge.badge-green 
              | #{ride.seats_available || 'Any'} seat#{ride.seats_available !== 1 ? 's' : ''} left
          
          .ride-meta
            span  #{ride.date} · #{ride.time || 'TBD'}
            if ride.duration
              span ⏱ ~#{ride.duration} min
            if ride.tag
              span.tag-pill= ride.tag
          
          .divider
          
          .ride-driver
            .avatar= ride.driver_initials || '??'
            div
              .driver-name= ride.driver_name || 'Anonymous Student'
              .stars 
                |  
                span.rating #{ride.driver_rating || '5.0'}
            .points-chip  #{ride.driver_points || 0} pts
  else
    .empty-state
      .empty-icon 
      h3 No rides found
      p Try searching for a different destination.
      a.gbtn-sm(href='/listing') View all rides

  .fab-container
    a.fab(href='/offer', title='Offer a Ride') +

  //- Injecting the ride data so JavaScript can read it
  script.
    var rideData = !{JSON.stringify(rides || [])};

  script.
    document.addEventListener('DOMContentLoaded', function() {
      // 1. Initialize map centered on your university coordinates
      // [Latitude, Longitude] - current example is for Roehampton area
      var map = L.map('map').setView([51.4594, -0.2412], 14); 

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
      }).addTo(map);

      // 2. Add Markers for each ride
      // Note: Since your DB doesn't have lat/long yet, 
      // we use a small random offset around the center for visualization.
      rideData.forEach(function(ride) {
        // Generating pseudo-coordinates based on the center for demo purposes
        // In your next step, you should store real lat/long in your database
        var lat = 51.4594 + (Math.random() - 0.5) * 0.01;
        var lng = -0.2412 + (Math.random() - 0.5) * 0.01;

        var marker = L.marker([lat, lng]).addTo(map);
        
        // Add a popup that shows the destination when clicked
        marker.bindPopup("<b>Destination:</b> " + ride.destination + "<br><a href='/detail/" + ride.id + "'>View Ride</a>");
      });
    });