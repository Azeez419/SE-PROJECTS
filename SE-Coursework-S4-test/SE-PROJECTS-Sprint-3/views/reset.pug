extends auth-layout

block content
  .auth-wrap
    .auth-card
      .auth-header
        a.logo-pill(href='/')
          img(src='/images/logo.svg', alt='CampusRide', height='38')
        p.auth-subtitle Create a new password

      .auth-body
        .step-indicator
          .step.step-done ✓
          .step-line.done
          .step.step-done ✓
          .step-line.done
          .step.step-active 3
        .step-labels
          span.done-label Enter email
          span.done-label Check inbox
          span New password

        if error
          .error-banner= error

        p.hint-text
          | Resetting password for:&nbsp;
          strong= email

        form(action=`/reset/${token}`, method='POST')
          input(type='hidden', name='token', value=token)

          .field
            label(for='password') New password
            input#password(
              type='password',
              name='password',
              placeholder='Min. 8 characters',
              minlength='8',
              required
            )
            .strength-bar
              .strength-fill#strength-fill
            .strength-label#strength-label Enter a new password

          .field
            label(for='confirm_password') Confirm new password
            input#confirm_password(
              type='password',
              name='confirm_password',
              placeholder='Re-enter new password',
              required
            )

          button.gbtn(type='submit') Set New Password →

  script.
    const fill = document.getElementById('strength-fill')
    const lbl  = document.getElementById('strength-label')
    document.getElementById('password').addEventListener('input', function () {
      const val = this.value; let s = 0
      if (val.length >= 8) s++
      if (/[A-Z]/.test(val)) s++
      if (/[0-9]/.test(val)) s++
      if (/[^A-Za-z0-9]/.test(val)) s++
      const c = [
        { w: '0%',   bg: '#dee2e6', t: 'Enter a new password' },
        { w: '25%',  bg: '#e74c3c', t: 'Weak' },
        { w: '50%',  bg: '#e67e22', t: 'Fair' },
        { w: '75%',  bg: '#f1c40f', t: 'Good' },
        { w: '100%', bg: '#52796F', t: 'Strong ✓' }
      ][s]
      fill.style.width = c.w; fill.style.background = c.bg
      lbl.textContent = c.t; lbl.style.color = c.bg === '#dee2e6' ? '#6c757d' : c.bg
    })
