extends layout

block content
  .profile-header
    .avatar.avatar-lg= user.initials
    div
      h2.profile-name= user.fname + ' ' + user.lname
      p.profile-email= user.email
      .profile-badges
        span.badge.badge-green Verified Student
        span.badge.badge-blue= user.role
    a.btn-outline(href='/profile/edit') Edit

  .stat-row
    .stat
      .stat-num= user.rides_offered || 0
      .stat-label Rides Offered
    .stat
      .stat-num= user.rides_taken || 0
      .stat-label Rides Taken
    .stat
      .stat-num= user.rating || '—'
      .stat-label Rating

  .card.points-card
    .points-row
      span.points-label My Points
      .points-chip ★ #{user.points || 0} points
    p.points-hint Redeem for café discounts or priority study room booking
    a.btn-accent(href='/redeem') Redeem Points

  .profile-tabs
    a.tab-btn(href='/profile',             class=tab==='offered'||!tab ? 'active' : '') Offered Rides
    a.tab-btn(href='/profile?tab=taken',   class=tab==='taken'         ? 'active' : '') Rides Taken
    a.tab-btn(href='/profile?tab=ratings', class=tab==='ratings'       ? 'active' : '') My Ratings

  .rides-list
    if rides && rides.length
      each ride in rides
        .card-sm.ride-summary
          div
            .ride-route-sm= ride.pickup + ' → ' + ride.destination
            .ride-date-sm= ride.date + ' · ' + ride.time
          span.badge(class=ride.status==='Active' ? 'badge-green' : 'badge-blue')= ride.status
    else
      .empty-state
        p No rides yet.
        if tab==='offered' || !tab
          a(href='/offer') Offer your first ride →
        else
          a(href='/listing') Find a ride →
