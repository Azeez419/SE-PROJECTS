extends auth-layout

block content
  .auth-wrap
    .auth-card
      .auth-header
        //- Ensure logo is inside static/images/logo.svg
        a.logo-pill(href='/')
          img(src='/images/logo.svg', alt='CampusRide', height='38')
        p.auth-subtitle Free rides for students, by students

      .auth-body
        .auth-badge
          .auth-badge-dot
          span Verified student network

        //- Display error messages from the server (e.g., "Invalid email or password")
        if error
          .error-banner(role="alert")
            span.icon  
            | #{error}

        //- Display success messages (e.g., "Account created! Please sign in.")
        if success
          .success-banner(role="alert")
            span.icon  
            | #{success}

        form(action='/login', method='POST')
          .field
            label(for='email') University email
            input#email(
              type='email',
              name='email',
              placeholder='yourname@roehampton.ac.uk',
              value=emailValue || '',
              required,
              autofocus
            )

          .field
            label(for='password')
              | Password
              a.forgot(href='/forgot') Forgot password?
            input#password(
              type='password',
              name='password',
              placeholder='Enter your password',
              required
            )

          button.gbtn(type='submit') Sign In →

        .auth-link-row
          p Don't have an account?&nbsp;
            a(href='/register') Register here
