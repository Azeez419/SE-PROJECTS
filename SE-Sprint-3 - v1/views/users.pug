extends layout

block content
  .page-header
    h2 Campus Community
    p Verified student network

  form.search-form(action='/users', method='GET')
    input.search-input(
      type='text',
      name='q',
      placeholder='Search students...',
      value=query || ''
    )
    button.gbtn-sm(type='submit') Search

  .card
    if users && users.length
      each u in users
        .user-row
          .avatar= u.initials
          .user-info
            .user-name= u.fname + ' ' + u.lname
            .user-role= u.role + ' · ' + u.ride_count + ' rides'
          .stars ★ #{u.rating || '—'}
          .points-chip ★ #{u.points || 0}
    else
      .empty-state No students found.
